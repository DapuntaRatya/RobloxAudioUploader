APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://127.0.0.1:8000

DATABASE_PATH=data/rau.sqlite3

SESSION_COOKIE_NAME=rau_session
SESSION_TTL_SECONDS=86400
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Generate with: python scripts/make_fernet_key.py
FERNET_KEY=CHANGE_ME_GENERATE_WITH_SCRIPT

MAX_ITEMS_PER_JOB=20
MAX_EXPERIENCES_PER_JOB=20
MAX_ACTIVE_JOBS_PER_SESSION=3
WORKER_COUNT=2

MAX_DOWNLOAD_CONCURRENT=4
MAX_ROBLOX_UPLOAD_CONCURRENT=3
MAX_PERMISSION_CONCURRENT=8

TEMP_DIR=app/temp

# Optional. Kosongkan jika memakai Docker atau imageio-ffmpeg.
FFMPEG_LOCATION=
